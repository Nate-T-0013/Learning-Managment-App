<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.LMS.Views.AssignmentDetailView"
             Title="AssignmentDetailView"
             NavigatedTo="ContentPage_NavigatedTo">
    <VerticalStackLayout>
        <Label Text="Name: "/>
        <Entry Text="{Binding Name}"/>
        <Label Text="Description: "/>
        <Entry Text="{Binding Description}"/>
        <Label x:Name="PointsWarning" Text="Invalid amount of available points."/>
        <Label Text="AvailablePoints: "/>
        <Entry x:Name="PointsEntry" Keyboard="Numeric"/>
        <Label x:Name="DateWarning" Text="Invalid due date."/>
        <Label Text="Due Date (mm/dd/yyyy): "/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Entry x:Name="MonthEntry" Keyboard="Numeric" Grid.Column="0"/>
            <Entry x:Name="DayEntry" Keyboard="Numeric" Grid.Column="1"/>
            <Entry x:Name="YearEntry" Keyboard="Numeric" Grid.Column="2"/>
        </Grid>
        <Label x:Name="WarningLabel" Text="Invalid module id."/>
        <Label Text="Id of Module to add to (0 for none): "/>
        <Entry x:Name="ModuleEntry" Keyboard="Numeric"/>
        <Button Text="Ok" Clicked="OkClicked"/>

        <Label Text="&#10;"/>
        <Button Text="Go Back" Clicked="GoBackClicked"/>
    </VerticalStackLayout>
</ContentPage>