<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.LMS.Views.ItemDetailView"
             Title="ItemDetailView"
             NavigatedTo="ContentPage_NavigatedTo">
    <VerticalStackLayout>
        <Label Text="Name: "/>
        <Entry Text="{Binding Name}"/>
        <Label x:Name="ContentLabel" Text="Content: "/>
        <Entry x:Name="ContentEntry" Text="{Binding Content}"/>
        <Label x:Name="PathLabel" Text="Path: "/>
        <Entry x:Name="PathEntry" Text="{Binding Path}"/>
        <Label x:Name="WarningLabel" Text="Invalid module id."/>
        <Label x:Name="ModuleLabel" Text="Id of Module to add to (required): "/>
        <Entry x:Name="ModuleEntry" Keyboard="Numeric"/>
        <Button Text="Ok" Clicked="OkClicked"/>
        
        <Label Text="&#10;"/>
        <Button Text="Go Back" Clicked="GoBackClicked"/>
    </VerticalStackLayout>
</ContentPage>