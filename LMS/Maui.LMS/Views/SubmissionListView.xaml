<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.LMS.Views.SubmissionListView"
             Title="SubmissionListView"
             NavigatedTo="ContentPage_NavigatedTo">
    <VerticalStackLayout 
        Spacing="10">
        <Label 
            Text="Submission List"
            VerticalOptions="Center" 
            HorizontalOptions="Center"/>
        <CollectionView
            ItemsSource="{Binding Submissions}"
            SelectedItem="{Binding SelectedItem}" SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.3*"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        
                        <Grid >
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Label Text="{Binding Id, StringFormat='Submission Id: {0}'}" Grid.Column="0"/>
                                <Label Text="{Binding StudentId, StringFormat='Student Id: {0}'}" FontAttributes="Bold" Grid.Column="1" HorizontalOptions="Center"/>
                            </Grid>
                            <Label Text="{Binding SubmissionDate}" Grid.Row="1"/>
                        </Grid>
                        
                        <Grid Grid.Column="1">
                            <Label Text="{Binding Points}"/>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Button Text="Grade Submission" Clicked="SelectClicked"/>
        <Label Text="&#10;"/>
        <Button Text="Go Back" Clicked="GoBackClicked"/>
    </VerticalStackLayout>
</ContentPage>