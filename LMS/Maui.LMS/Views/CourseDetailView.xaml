<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.LMS.Views.CourseDetailView"
             Title="CourseDetailView"
             NavigatedTo="ContentPage_NavigatedTo">
    <VerticalStackLayout
        Spacing="10">
        <Label Text="Name: "/>
        <Entry Text="{Binding Name}"/>
        <Label Text="Code: "/>
        <Entry Text="{Binding Code}"/>
        <Label Text="Description: "/>
        <Entry Text="{Binding Description}"/>
        <Label x:Name="SemesterWarning" Text="Invalid Semester. "/>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Label Text="Semester Season: " Grid.Column="0" Grid.Row="0"/>
            <Entry Text="{Binding SemesterSeason}" Grid.Column="0" Grid.Row="1"/>
            <Label Text="Semester Year: " Grid.Column="1" Grid.Row="0"/>
            <Entry Text="{Binding SemesterYear}" Keyboard="Numeric" Grid.Column="1" Grid.Row="1"/>
        </Grid>
        <Button Text="Ok" Clicked="OkClicked"/>

        <Label Text="&#10;"/>
        <Button Text="Go Back" Clicked="GoBackClicked"/>
    </VerticalStackLayout>
</ContentPage>