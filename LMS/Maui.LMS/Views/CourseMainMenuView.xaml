<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.LMS.Views.CourseMainMenuView"
             Title="{Binding Currentcourse.Name}"
             NavigatedTo="ContentPage_NavigatedTo">
    <VerticalStackLayout
        Spacing="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Text="{Binding Currentcourse.Description}"/>
            <Label Grid.Column="1" x:Name="StudentGrade" Text="{Binding Grade.LetterGrade, StringFormat='Grade: {0}'}" HorizontalOptions="Center"/>
        </Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="0.4*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <VerticalStackLayout Grid.Column="0" Spacing="10">
                <Button Text="Home Page" IsEnabled="False"/>
                <Button Text="Modules" Clicked="ModulesClicked"/>
                <Button Text="Assignments" Clicked="AssignmentsClicked"/>
                <Button Text="Grades" Clicked="GradesClicked"/>
                <Button x:Name="StudentListButton" Text="Student list" Clicked="StudentListClicked"/>
                <Label Text="&#10;"/>
                <Button Text="Go Back" Clicked="GoBackClicked"/>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Spacing="10">
                <Label x:Name="AnnouncementWarning" Text="Invalid Announcment"/>
                <Entry x:Name="AnnouncementEntry" Text=""/>
                <Button x:Name="MakeAnnouncement" Text="Make Announcement" Clicked="MakeAnnouncementClicked"/>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" Spacing="10">
                <Label 
                Text="Announcemets"
                VerticalOptions="Center" 
                HorizontalOptions="Center" />
                <CollectionView
                     ItemsSource="{Binding Announcements}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="5" Padding="10">
                                <Label Text="{Binding .}" FontSize="14" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Grid>
        
        <Label Text="&#10;"/>
        <Button Text="Go Back" Clicked="GoBackClicked"/>
    </VerticalStackLayout>
</ContentPage>